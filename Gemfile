source "https://rubygems.org"

# This is the "Engine" of your site
gem "jekyll", "~> 4.3.3"

# These are the "Power-ups" (Plugins) we added to your _config.yml
group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end

# This helps GitHub Pages understand your site
gem "github-pages", group: :jekyll_plugins